{
  "name": "vue-page-review",
  "version": "0.7.4",
  "description": "A Vue 3 page review tool for collecting UI feedback with element selection and viewport boxing.",
  "type": "module",
  "main": "./dist/vue-page-review.umd.cjs",
  "module": "./dist/vue-page-review.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-page-review.js",
      "require": "./dist/vue-page-review.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && node --input-type=module -e \"import fs from 'node:fs'; fs.copyFileSync('src/style.css', 'dist/style.css')\"",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.0.0",
    "element-plus": "^2.8.0",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "@element-plus/icons-vue": {
      "optional": true
    },
    "element-plus": {
      "optional": true
    }
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "element-plus": "^2.14.3",
    "vite": "^8.1.4",
    "vue": "^3.5.39"
  },
  "keywords": [
    "vue3",
    "review",
    "feedback",
    "ui-review",
    "annotation"
  ],
  "license": "MIT",
  "dependencies": {
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1"
  }
}
